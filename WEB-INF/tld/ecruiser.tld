		</attribute>
		<attribute>
			<description>
				<![CDATA[
           
        The flag indicating whether DataTable should load rows using AJAX requests.
        This way DataTable will render a minimum number of rows and load through AJAX requests other rows
        if it is scrolled into an area with no rows.
        This will allow you to display millions of records with good and constant performance.
        Performance may vary depending on the renderer or browser.
        
        ]]>
			</description>
			<name>ajaxLoading</name>
			<required>false</required>
			<deferred-value>
				<type>
					boolean
				</type>
			</deferred-value>
		</attribute>
