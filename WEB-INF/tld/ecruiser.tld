	<tag>
		<description>
			<![CDATA[
      Renders a DataTable with selection behavior.
    ]]>
		</description>
		<name>selecttable</name>
		<tag-class>ecruiser.advanced.datatable.tag.SelectTableTag</tag-class>
		<body-content>JSP</body-content>
		<attribute>
			<description>
				<![CDATA[
        The flag that controls whether events of this component use the AJAX request mechanism or not.
      ]]>
			</description>
			<name>ajax</name>
			<required>false</required>
			<deferred-value>
				<type>
					boolean
				</type>
			</deferred-value>
		</attribute>
		<attribute>
			<description>
				<![CDATA[
           
        The flag indicating whether DataTable should load rows using AJAX requests.
        This way DataTable will render a minimum number of rows and load through AJAX requests other rows
        if it is scrolled into an area with no rows.
        This will allow you to display millions of records with good and constant performance.
        Performance may vary depending on the renderer or browser.
        
        ]]>
			</description>
			<name>ajaxLoading</name>
			<required>false</required>
			<deferred-value>
				<type>
					boolean
				</type>
			</deferred-value>
		</attribute>
		<attribute>
			<description>
				<![CDATA[
        The id of the component that will do visual indication of ajax request. Default value is "default". 
      ]]>
			</description>
			<name>ajaxStatusId</name>
			<required>false</required>
			<deferred-value>
				<type>
					java.lang.String
				</type>
			</deferred-value>
		</attribute>
		<attribute>
			<description>
				<![CDATA[
        The horizontal alignment of the table with respect to any surrounding text.
      ]]>
			</description>
			<name>align</name>
