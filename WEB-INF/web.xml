<?xml version='1.0' encoding='UTF-8'?>

<!DOCTYPE web-app PUBLIC
    "-//Sun Microsystems, Inc.//DTD Web Application 2.3//EN"
    "http://java.sun.com/dtd/web-app_2_3.dtd">

<web-app>

  <display-name>LabWare LIMS Application</display-name>
  <description>
    LabWare LIMS Application
  </description>

  <context-param>
    <param-name>javax.faces.STATE_SAVING_METHOD</param-name>
    <param-value>server</param-value>
  </context-param>

  <context-param>
    <param-name>com.sun.faces.enableRestoreView11Compatibility</param-name>
    <param-value>true</param-value>
  </context-param>

  <context-param>
    <param-name>com.sun.faces.sendPoweredByHeader</param-name>
    <param-value>false</param-value>
  </context-param>

  <listener>
    <listener-class>labware.web.control.WebLIMSSessionListener</listener-class>
  </listener>

  <!-- Ensure encoding is set to UTF-8  -->
  <filter>
    <filter-name>sessionInvalidatedFilter</filter-name>
    <filter-class>labware.web.control.SessionInvalidatedFilter</filter-class>
  </filter>

  <filter>
    <filter-name>loggingFilter</filter-name>
    <filter-class>ecruiser.util.LogFilter</filter-class>
  </filter>

  <filter>
    <filter-name>WebLIMSFilter</filter-name>
    <filter-class>labware.web.control.WebLIMSFilter</filter-class>
    <init-param>
      <param-name>mode</param-name>
      <param-value>SAMEORIGIN</param-value>
    </init-param>
  </filter>

  <filter>
    <filter-name>WSFilter</filter-name>
    <filter-class>labware.web.ws.control.WSFilter</filter-class>
  </filter>

  <filter>
    <filter-name>LoginFilter</filter-name>
    <filter-class>labware.web.control.LoginFilter</filter-class>
  </filter>

  <filter>
    <filter-name>DenialOfServiceAttackFilter</filter-name>
    <filter-class>labware.web.control.DenialOfServiceAttackFilter</filter-class>
    <init-param>
      <param-name>concurrent_user</param-name>
      <param-value>10</param-value>
    </init-param>
    <init-param>
      <param-name>time_to_deny</param-name>
      <param-value>1</param-value>
    </init-param>
  </filter>
  <filter>
    <filter-name>DateTimeFormatFilter</filter-name>
    <filter-class>labware.web.ws.control.LabWareWebServicesFilter</filter-class>
  </filter>

  <filter-mapping>
    <filter-name>sessionInvalidatedFilter</filter-name>
    <servlet-name>Faces Servlet</servlet-name>
  </filter-mapping>

  <filter-mapping>
    <filter-name>DenialOfServiceAttackFilter</filter-name>
    <url-pattern>*.htm</url-pattern>
  </filter-mapping>

  <filter-mapping>
    <filter-name>WebLIMSFilter</filter-name>
    <servlet-name>Faces Servlet</servlet-name>
  </filter-mapping>

  <filter-mapping>
    <filter-name>LoginFilter</filter-name>
    <url-pattern>*.htm</url-pattern>
  </filter-mapping>

  <filter-mapping>
    <filter-name>loggingFilter</filter-name>
    <servlet-name>Faces Servlet</servlet-name>
  </filter-mapping>


  <filter-mapping>
    <filter-name>DateTimeFormatFilter</filter-name>
    <servlet-name>AxisServlet</servlet-name>
  </filter-mapping>


  <filter-mapping>
    <filter-name>WSFilter</filter-name>
    <servlet-name>AxisServlet</servlet-name>
  </filter-mapping>

  <!-- Uncomment below to ensure listener loads on older application servers -->
  <!--<listener>-->
  <!--<listener-class>com.sun.faces.config.ConfigureListener</listener-class>-->
  <!--</listener>-->
  <servlet>
    <servlet-name>CommonServlet</servlet-name>
    <display-name>Common Servlet</display-name>
    <servlet-class>labware.web.control.CommonFileServlet</servlet-class>
    <load-on-startup>1</load-on-startup>
  </servlet>

  <servlet>
    <servlet-name>ImagesServlet</servlet-name>
    <display-name>Images Servlet</display-name>
    <servlet-class>labware.web.control.ImagesFileServlet</servlet-class>
    <load-on-startup>1</load-on-startup>
  </servlet>


  <!-- Faces Servlet -->
  <servlet>
    <servlet-name>Faces Servlet</servlet-name>
    <servlet-class>javax.faces.webapp.FacesServlet</servlet-class>
    <load-on-startup>1</load-on-startup>
  </servlet>

  <servlet>
    <servlet-name>AxisServlet</servlet-name>
    <display-name>Apache-Axis Servlet</display-name>
    <servlet-class>org.apache.axis2.transport.http.AxisServlet</servlet-class>
    <load-on-startup>1</load-on-startup>
  </servlet>

  <!-- extension mapping -->
  <servlet-mapping>
    <servlet-name>Faces Servlet</servlet-name>
    <url-pattern>*.htm</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>Faces Servlet</servlet-name>
    <url-pattern>*.pdf</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>AxisServlet</servlet-name>
    <url-pattern>/servlet/AxisServlet</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>CommonServlet</servlet-name>
    <url-pattern>/common/*</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>CommonServlet</servlet-name>
    <url-pattern>/admin/common/*</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>ImagesServlet</servlet-name>
    <url-pattern>/images/*</url-pattern>
  </servlet-mapping>


  <servlet-mapping>
    <servlet-name>AxisServlet</servlet-name>
    <url-pattern>*.jws</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>AxisServlet</servlet-name>
    <url-pattern>/services/*</url-pattern>
  </servlet-mapping>

  <session-config>
    <session-timeout>25</session-timeout>
  </session-config>

  <!-- currently the W3C havent settled on a media type for WSDL;
http://www.w3.org/TR/2003/WD-wsdl12-20030303/#ietf-draft
for now we go with the basic 'it's XML' response -->
  <mime-mapping>
    <extension>wsdl</extension>
    <mime-type>text/xml</mime-type>
  </mime-mapping>

  <mime-mapping>
    <extension>xsd</extension>
    <mime-type>text/xml</mime-type>
  </mime-mapping>

  <mime-mapping>
    <extension>inc</extension>
    <mime-type>text/plain</mime-type>
  </mime-mapping>

  <!-- Welcome file -->
  <welcome-file-list>
    <welcome-file>index.htm</welcome-file>
  </welcome-file-list>

  <security-constraint>
    <display-name>Security for resources</display-name>
    <web-resource-collection>
      <web-resource-name>Restricted pages</web-resource-name>
      <url-pattern>/mainpane.html</url-pattern>
      <url-pattern>/patch/*</url-pattern>
      <url-pattern>/log/*</url-pattern>
      <url-pattern>/admin/applyPatch.jsp</url-pattern>
      <url-pattern>/admin/login.jsp</url-pattern>
      <url-pattern>/admin/SelectRoutine.jsp</url-pattern>
      <url-pattern>/admin/Datasource.jsp</url-pattern>
      <url-pattern>/admin/SSOMeta.jsp</url-pattern>
      <url-pattern>/admin/EmailAlert.jsp</url-pattern>
      <url-pattern>/admin/InvokeFx.jsp</url-pattern>
      <url-pattern>/admin/LIMSInstance.jsp</url-pattern>
      <url-pattern>/admin/Logging.jsp</url-pattern>
      <url-pattern>/admin/Logview.jsp</url-pattern>
      <url-pattern>/admin/MonitorConnections.jsp</url-pattern>
      <url-pattern>/admin/MonitorLIMSInstance.jsp</url-pattern>
      <url-pattern>/admin/Monitor_LeftPane.jsp</url-pattern>
      <url-pattern>/admin/Monitor_LeftPane.htm</url-pattern>
      <url-pattern>/admin/SelectFx.jsp</url-pattern>
      <url-pattern>/admin/Services.jsp</url-pattern>
      <url-pattern>/admin/SetUp_LeftPane.jsp</url-pattern>
      <url-pattern>/admin/System.jsp</url-pattern>
      <url-pattern>/admin/top.jsp</url-pattern>
      <url-pattern>/admin/User.jsp</url-pattern>
      <url-pattern>/admin/WarUpdator.jsp</url-pattern>
      <url-pattern>/admin/WsConnectionLogin.jsp</url-pattern>
      <url-pattern>/admin/WSConn_LeftPane.jsp</url-pattern>
      <url-pattern>/admin/WSConn_SelectFxLeftPane.jsp</url-pattern>
      <url-pattern>/admin/SetUp_LeftPane.htm</url-pattern>
      <url-pattern>/admin/WSConn_LeftPane.htm</url-pattern>
      <url-pattern>/admin/top.htm</url-pattern>
    </web-resource-collection>
    <auth-constraint>
      <description>Security Constraint for the resources like Jsps and html files</description>
      <role-name>*</role-name>
    </auth-constraint>
  </security-constraint>

  <!--Added to fix LG358CS (8) -->
  <security-constraint>
    <display-name>Deny all HTTP methods except GET and POST</display-name>
    <web-resource-collection>
      <web-resource-name>HTTP methods</web-resource-name>
      <url-pattern>/*</url-pattern>
      <http-method-omission>GET</http-method-omission>
      <http-method-omission>POST</http-method-omission>
    </web-resource-collection>
    <auth-constraint/>
  </security-constraint>

  <error-page>
    <!-- Missing login -->
    <error-code>401</error-code>
    <location>/error.htm</location>
  </error-page>
  <error-page>
    <!-- Forbidden directory listing -->
    <error-code>403</error-code>
    <location>/error.htm</location>
  </error-page>
  <error-page>
    <!-- Missing resource -->
    <error-code>404</error-code>
    <location>/error.htm</location>
  </error-page>
  <error-page>
    <!-- Uncaught exception -->
    <error-code>500</error-code>
    <location>/error.htm</location>
  </error-page>
  <error-page>
    <!-- Unsupported servlet method -->
    <error-code>503</error-code>
    <location>/error.htm</location>
  </error-page>

</web-app>
