  <!-- webdialog entry -->
  <tag>
    <description>
      <![CDATA[
    Renders a window component.
  ]]>
    </description>
    <name>window</name>
    <tag-class>labware.web.component.WebDialogWindowTag</tag-class>
    <body-content>JSP</body-content>
    <attribute>
      <description>
        <![CDATA[
        The flag that controls whether events of this component use the AJAX request mechanism or not.
      ]]>
      </description>
      <name>ajax</name>
      <required>false</required>
      <deferred-value>
        <type>
          boolean
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
        Flag that will cause the popup to get it's content from server before popup.
      ]]>
      </description>
      <name>ajaxLoading</name>
      <required>false</required>
      <deferred-value>
        <type>
          boolean
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
        The id of the component that will do visual indication of ajax request. Default value is "default".
      ]]>
      </description>
      <name>ajaxStatusId</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
             The horizontal alignment of any content in the component.
           ]]>
      </description>
      <name>align</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
             The background style of this element per the CSS spec.
           ]]>
      </description>
      <name>background</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
        The special attribute that allows binding of this component instance to a backing bean.
      ]]>
      </description>
      <name>binding</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
             The border style of this element per the CSS spec - for example, #000066 1px solid.
           ]]>
      </description>
      <name>border</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
        The style class use to define attributes for the buttons in the Window.
        <p>Default value is <code>windowButtons</code>.</p>
      ]]>
      </description>
      <name>buttonStyle</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
        The comma separated value list wich defines custom tooltip
        messages when mouse is over the window buttons.Commna
        separated value must include four messages in the following
        order : first for minimize button, second for maximize button,
        third for restore button and the last one for close button.
        <p>Default value is : <code>Minimize,Maximize,Restore,Close</code></p>
      ]]>
      </description>
      <name>buttonTitle</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
        The path to the image used for the close icon.
        <p>It supports a comma separated list of normal image + hover image + down image</p>
      ]]>
      </description>
      <name>closeIcon</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
        Flag indicating if popup should be closed on escape key or not.
      ]]>
      </description>
      <name>closeOnEscape</name>
      <required>false</required>
      <deferred-value>
        <type>
          boolean
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
             The color of the text in this element per the CSS spec.
           ]]>
      </description>
      <name>color</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
        The style class used to define the attributes for the content in the Window.
        <p>Default value is <code>windowContent</code>.</p>
      ]]>
      </description>
      <name>contentStyle</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
             The style of the cursor when it passes over this element per the CSS spec.
           ]]>
      </description>
      <name>cursor</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
      The text direction as related to the lang attribute. Accpted values are
      ltr (left to right) and rtl (right to left).
    ]]>
      </description>
      <name>dir</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
             The CSS property that controls the way content in this element is displayed (compact, run-in, etc).
           ]]>
      </description>
      <name>display</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
      The string identifier that defines the type of drag object transferred by this component.
    ]]>
      </description>
      <name>dragType</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
      The comma separated list of drag types that this component can accept.
    ]]>
      </description>
      <name>dropTypes</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
        The special event control parameter which can later be retrieved from the ClientEvent.
      ]]>
      </description>
      <name>eventParam</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
        Flat that speficify if we should exclude the popup itself as a hide trigger source.
      ]]>
      </description>
      <name>excludePopupSource</name>
      <required>false</required>
      <deferred-value>
        <type>
          boolean
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
         Flat that speficify if we should exclude the popup trigger source as a hide trigger source.
      ]]>
      </description>
      <name>excludeTriggerSource</name>
      <required>false</required>
      <deferred-value>
        <type>
          boolean
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
        The height of this component per the CSS spec.
      ]]>
      </description>
      <name>height</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
        Hide trigger event that will trigger the popup to hide.
        Can be one of following :
        <ul>
        <li>click
        <li>rightclick
        <li>dblclick
        <li>mousedown           :default
        <li>mouseout
        <li>key                 :when trigger component has focus
        <li>[modifier]-[key]    :when trigger component has focus
      ]]>
      </description>
      <name>hideTrigger</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
        The JSF identifier for this component.
      ]]>
      </description>
      <name>id</name>
      <required>false</required>
      <rtexprvalue>true</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
        The flag that determines if client events for this component are fired in the Apply Request Values phase
        (when true) or in the Invoke Application phase (when false and the default).
      ]]>
      </description>
      <name>immediateEvent</name>
      <required>false</required>
      <deferred-value>
        <type>
          boolean
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
        The text that may be used by other components to create a label for this value holder.
      ]]>
      </description>
      <name>label</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
      The ISO standard language identifier for the enclosed content such as fr for French
      and en for English.
    ]]>
      </description>
      <name>lang</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
        The left of this component per the CSS spec.
      ]]>
      </description>
      <name>left</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
        The path to the image used for the maximize icon.
        <p>It supports a comma separated list of normal image + hover image + down image</p>
      ]]>
      </description>
      <name>maximizeIcon</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
        The path to the image used for the minimize icon.
        <p>It supports a comma separated list of normal image + hover image + down image</p>
      ]]>
      </description>
      <name>minimizeIcon</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
        Flag that makes popup modal when is displayed.
      ]]>
      </description>
      <name>modal</name>
      <required>false</required>
      <deferred-value>
        <type>
          boolean
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
        Style class that will be applied to modal layer when window will be opened
      ]]>
      </description>
      <name>modalLayerStyleClass</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
        The flag that defines whether users can move the window.
        Set the property to 'true' to allow window movement.
      ]]>
      </description>
      <name>movable</name>
      <required>false</required>
      <deferred-value>
        <type>
          boolean
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
      The action to take when the mouse button is clicked over the element.
    ]]>
      </description>
      <name>onclick</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
        The action to take when the Window is closed.
      ]]>
      </description>
      <name>onclose</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
      The action to take when the mouse button is double-clicked over the element.
    ]]>
      </description>
      <name>ondblclick</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
      The action to take when a drag gesture is starting on this component. Requires that the dragType
      property is also set or the mavable property is set to true.
    ]]>
      </description>
      <name>ondrag</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
      The action to take when a drop gesture is made on this component. Requires that the dropTypes property
      is also set.
    ]]>
      </description>
      <name>ondrop</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
        The attribute that causes an event to occur when this control will hide.
      ]]>
      </description>
      <name>onhide</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
      The action to take when a key is pressed.
    ]]>
      </description>
      <name>onkeydown</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
      The action to take when a key is pressed and subsequently released.
    ]]>
      </description>
      <name>onkeypress</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
      The action to take when a key is released.
    ]]>
      </description>
      <name>onkeyup</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
        The action to take when the Window is maximized.
      ]]>
      </description>
      <name>onmaximize</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
        The action to take when the Window is minimized.
      ]]>
      </description>
      <name>onminimize</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
      The action to take when the mouse button is pressed over the element.
    ]]>
      </description>
      <name>onmousedown</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
      The action to take when the mouse moves over the element.
    ]]>
      </description>
      <name>onmousemove</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
      The action to take when the mouse leaves the element's area.
    ]]>
      </description>
      <name>onmouseout</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
      The action to take when the mouse moves onto an element.
    ]]>
      </description>
      <name>onmouseover</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
      The action to take when the mouse button is released.
    ]]>
      </description>
      <name>onmouseup</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
        The action to take when the Window is opened.
      ]]>
      </description>
      <name>onopen</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
        The attribute that causes an event to occur when this control will popup.
      ]]>
      </description>
      <name>onpopup</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
        The action to take when the Window is restored.
      ]]>
      </description>
      <name>onrestore</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
