    </attribute>
    <attribute>
      <description>
        <![CDATA[

         The style class applied on a top menu cell which is disabled.
         The default is <code>topCellDisabled</code>

      ]]>
      </description>
      <name>topCellDisabledStyle</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[

         The style class applied on a top menu cell when mouse is over the cell.
         The default is <code>topCellHover</code>

      ]]>
      </description>
      <name>topCellHoverStyle</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[

         The style class applied on the top menu cells. A top menu cell is the cell placed    <br>
         on the menu bar. Style class applied on a top menu cell can be specified also as a   <br>
         comma separated value list of style classes. A menu cell is divided in four areas <br>
         as follows : <br>
         <p>
            <ul>
                <li>left area : for icon if specified or any other custom component</li>
                <li>text area : for menu cell text</li>
                <li>shortCut area : for shortcut key text</li>
                <li>right area : for expand icon if menu cell has children or for any custom component.</li>
            </ul>
         </p><br>
         Comma separated value list contains 5 style classes. The order is the <br>
         following : overall menu cell style class, left style class, text style class, shourcut key <br>
         style class and right style class. Any of the style class values from comma separated list can be empty <br>

         The default is <code>topCell</code>

      ]]>
      </description>
      <name>topCellStyle</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
        The underlying value object.
      ]]>
      </description>
      <name>value</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.Object
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
             The property that determines if this element is visible per the CSS spec.
           ]]>
      </description>
      <name>visibility</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[

        Flag that modifies menu bar normal behavior. When true hovering over the top menu cells <br>
        will automatically expand the submenu. In the normal way this will happen only if user  <br>
        clicks on a top menu cell. <br>
        The default is <code>false</code>

      ]]>
      </description>
      <name>webMode</name>
      <required>false</required>
      <deferred-value>
        <type>
          boolean
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
             The width of this component per the CSS spec.
           ]]>
      </description>
      <name>width</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
             The property that determines the order of elements that overlap each other per the CSS spec.
           ]]>
      </description>
      <name>zindex</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>

  </tag>
  <!-- main menubar entry ends -->
  <tag>
    <description>
