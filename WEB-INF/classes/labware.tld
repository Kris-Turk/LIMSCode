      </description>
      <name>border</name>
      <required>false</required>
      <deferred-value>
        <type>
          java.lang.String
        </type>
      </deferred-value>
    </attribute>
    <attribute>
      <description>
        <![CDATA[
             The color of the text in this element per the CSS spec.
