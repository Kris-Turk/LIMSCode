<taglib xmlns="http://java.sun.com/xml/ns/javaee"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://java.sun.com/xml/ns/javaee http://java.sun.com/xml/ns/javaee/web-jsptaglibrary_2_1.xsd"
        version="2.1">


  <!-- ============== Tag Library Description Elements ============= -->
  <description>
    This tag library contains the tag definition for the ECruiser JSF components.
  </description>
  <tlib-version>1.0</tlib-version>
  <short-name>lab</short-name>
  <uri>http://www.labware.com/components</uri>


  <tag>
    <description>
      Renders an HTML div element.
    </description>
    <name>toolbar</name>
    <tag-class>labware.web.component.toolbar.ToolBarTag</tag-class>
    <body-content>JSP</body-content>
    <attribute>
      <description>
        The JSF action property.
      </description>
      <name>action</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The JSF action listener property.
      </description>
      <name>actionListener</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The flag that indicates whether this field component should be included in form processing.
      </description>
      <name>activeField</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The flag that controls whether events of this component use the AJAX request mechanism or not.
      </description>
      <name>ajax</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The horizontal alignment of any content in the component.
      </description>
      <name>align</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The flag that allows this component to support drag operations. The default is false.
      </description>
      <name>allowDrag</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The flag that allows this component to support drop operations. The default is false.
      </description>
      <name>allowDrop</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The flag for enabling or disabling the auto-discovery mechanism on this component.
      </description>
      <name>autoDiscover</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The background style of this element per the CSS spec.
      </description>
      <name>background</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The value binding expression (if any) used to wire up this component
      </description>
      <name>binding</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The border style of this element per the CSS spec - for example, #000066 1px solid.
      </description>
      <name>border</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The color of the text in this element per the CSS spec.
      </description>
      <name>color</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The type of the javax.faces.convert.Converter associated with this field component.
      </description>
      <name>converter</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The style of the cursor when it passes over this element per the CSS spec.
      </description>
      <name>cursor</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The column name in the HTML data source that supplies the bound data. This is a direct pass-through to
        the HTML datafld attribute and not currently related to any ECruiser or JSF data source.
      </description>
      <name>datafld</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The format of the bound data. This is a direct pass-through to the HTML dataformatas attribute and not
        currently related to any ECruiser or JSF data source.
      </description>
      <name>dataformatas</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The ID of the data source that supplies the bound data. This is a direct pass-through to the HTML
        datasrc attribute and not currently related to any ECruiser or JSF data source.
      </description>
      <name>datasrc</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The text direction as related to the lang attribute. Accpted values are ltr (left to right) and rtl
        (right to left).
      </description>
      <name>dir</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The CSS property that controls the way content in this element is displayed (compact, run-in, etc).
      </description>
      <name>display</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The string identifier that defines the type of drag object transferred by this component.
      </description>
      <name>dragType</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The comma separated list of drag types that this component can accept.
      </description>
      <name>dropTypes</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The special event parameter that can be retrieved from the resulting ClientEvent.
      </description>
      <name>eventParam</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The height of this component per the CSS spec.
      </description>
      <name>height</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The JSF identifier for this component.
      </description>
      <name>id</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The JSF immediate flag.
      </description>
      <name>immediate</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The text that will be used in the label component if there is one.
      </description>
      <name>labelText</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The ISO standard language identifier for the enclosed content such as fr for French and en for English.
      </description>
      <name>lang</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The dimension that positions this component's left edge per the CSS spec. This property works in
        conjunction with the position property.
      </description>
      <name>left</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The name property which is normally the same as the ID for this component.
      </description>
      <name>name</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The action to take when the mouse button is clicked over the element.
      </description>
      <name>onclick</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>

    </attribute>
    <attribute>
      <description>
        The action to take when the mouse button is double-clicked over the element.
      </description>
      <name>ondblclick</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The action to take when a key is pressed.
      </description>
      <name>onkeydown</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The action to take when a key is pressed and subsequently released.
      </description>
      <name>onkeypress</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The action to take when a key is released.
      </description>
      <name>onkeyup</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The action to take when the mouse button is pressed over the element.
      </description>
      <name>onmousedown</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The action to take when the mouse moves over the element.
      </description>
      <name>onmousemove</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The action to take when the mouse leaves the element's area.
      </description>
      <name>onmouseout</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The action to take when the mouse moves onto an element.
      </description>
      <name>onmouseover</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The action to take when the mouse button is released.
      </description>
      <name>onmouseup</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The CSS property that handles the situation when content does not fit.
      </description>
      <name>overflow</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The property that defines the padding around any content within this element per the CSS spec.
      </description>
      <name>padding</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The CSS property that defines the region for which the top and left coordinates are relative to.
      </description>
      <name>position</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The boolean flag that when false suppresses rendering. The default is true.
      </description>
      <name>rendered</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The value of the rendersChildren flag for this component.
      </description>
      <name>rendersChildren</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The style used by this component.
      </description>
      <name>style</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        A style class or classes used by this component.
      </description>
      <name>styleClass</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The name of a form that will be submitted by client events.
      </description>
      <name>submitForm</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The text that is displayed by this component.
      </description>
      <name>text</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The advisory text for this component.
      </description>
      <name>title</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The dimension that positions this component's top edge per the CSS spec. This property works in
        conjunction with the position property.
      </description>
      <name>top</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The degree of transparency of this element per the CSS spec.
      </description>
      <name>transparency</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The value of this field component.
      </description>
      <name>value</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The property that determines if this element is visible per the CSS spec.
      </description>
      <name>visibility</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The width of this component per the CSS spec.
      </description>
      <name>width</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The property that determines the order of elements that overlap each other per the CSS spec.
      </description>
      <name>zindex</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>The ID of the popup component.</description>
      <name>popupComponent</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>The disabled styles that will be used by child ToolBar Cells</description>
      <name>disabledCellStyle</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
  </tag>

