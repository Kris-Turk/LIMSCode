    </attribute>
    <attribute>
      <description>
        A style class or classes used by this component.
      </description>
      <name>styleClass</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The name of a form that will be submitted by client events.
      </description>
      <name>submitForm</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        Defines the style of the tab control.
      </description>
      <name>tabControlStyle</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        Defines the style class for tabs.
      </description>
      <name>tabStyle</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The number that represents this link's position in the tabbing order.
      </description>
      <name>tabindex</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The text that is displayed by this component.
      </description>
      <name>text</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The advisory text for this component.
      </description>
      <name>title</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The dimension that positions this component's top edge per the CSS spec. This property works in conjunction with
        the position property.
      </description>
      <name>top</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The degree of transparency of this element per the CSS spec.
      </description>
      <name>transparency</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The value of this field component.
      </description>
      <name>value</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The property that determines if this element is visible per the CSS spec.
      </description>
      <name>visibility</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The width of this component per the CSS spec.
      </description>
      <name>width</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        Flag indicating if the tabs are wrap or no.
      </description>
      <name>wrapTabs</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        Flag indicating if the label of tabs are wrap or no.
      </description>
      <name>wrapText</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
    <attribute>
      <description>
        The property that determines the order of elements that overlap each other per the CSS spec.
      </description>
      <name>zindex</name>
      <required>false</required>
      <rtexprvalue>false</rtexprvalue>
    </attribute>
  </tag>
  <tag>
    <description>
      Renders component that manage a tabcontrol and the content.
    </description>
    <name>mainpaneview</name>
    <tag-class>labware.web.component.mainpaneview.MainPaneViewTag</tag-class>
