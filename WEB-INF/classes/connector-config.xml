<?xml version="1.0" encoding="UTF-8"?>
<config>
  <dao>
    <!-- IMPLEMENTATION CLASSES FOR DIFFERENT COMPONENTS OF CONFIG MANAGER -->
    <configdao>
      <classname>labware.config.XmlDbConfigDAO</classname>
    </configdao>
    <datasourcesdao>
      <classname>labware.config.JNDIDataSourceDAO</classname>
    </datasourcesdao>
  </dao>
  <connector>
      <resource-monitor-period>6000</resource-monitor-period>
      <resource-monitor-delay>2000</resource-monitor-delay>
      <sotimeout>300</sotimeout>
      <lims-activity-timeout>60</lims-activity-timeout>
      <admin>
          <version>8.0.0.D</version>
          <ws-operation-name>invoke</ws-operation-name>
          <ws-hot-update>true</ws-hot-update>
          <ws-attachment-option>SwA</ws-attachment-option>
          <append-servicename-in-namespace>false</append-servicename-in-namespace>
      </admin>
    <user-agents>
      <user-agent>
        <match-string>symbian</match-string>
        <type>mobile</type>
      </user-agent>
      <user-agent>
        <match-string>msie</match-string>
        <type>tablet</type>
      </user-agent>
      <user-agent>
        <match-string>symbian</match-string>
        <type>mobile</type>
      </user-agent>
    </user-agents>
  </connector>
</config>
